# Example environment variables for Kotoby
SECRET_KEY=change_this_to_a_long_random_string_at_least_32_chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminPass123
DATABASE_URL=sqlite:///database.db
FLASK_DEBUG=True
MAX_UPLOAD_MB=100
# ============================================================
# Kotoby – Environment Variables Template
# Copy this file to .env and fill in your actual values
# !! Do NOT put real secrets here !!
# ============================================================

# Flask core
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_KEY_AT_LEAST_32_CHARS
FLASK_DEBUG=False
FLASK_ENV=production

# Database (SQLite for dev, use PostgreSQL/MySQL for production)
DATABASE_URL=sqlite:///database.db

# Admin account created on first run
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Upload limit in megabytes (default 100)
MAX_UPLOAD_MB=100
